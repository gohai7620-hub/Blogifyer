<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - All Users</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .user-card { transition: all 0.3s; }
        .user-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
        .blog-list { max-height: 200px; overflow-y: auto; }
    </style>
</head>
<body class="bg-light">
    <div class="container mt-4">
        <h1 class="mb-4">👥 All Users & Their Blogs</h1>
        <p class="text-muted">Total Users: <%= users.length %></p>

        <% users.forEach(user => { %>
            <div class="card user-card mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="d-flex align-items-center">
                            <img src="<%= user.profileImageURL %>" 
                                 alt="Profile" 
                                 class="rounded-circle me-3" 
                                 width="50" height="50">
                            <div>
                                <h5><%= user.fullName %></h5>
                                <p class="mb-1 text-muted"><%= user.email %></p>
                                <span class="badge <%= user.role === 'ADMIN' ? 'bg-danger' : 'bg-primary' %>">
                                    <%= user.role %>
                                </span>
                            </div>
                        </div>

                        <button class="btn btn-danger btn-sm delete-btn" 
                                data-id="<%= user._id %>">
                            Delete User
                        </button>
                    </div>

                    <hr>
                    <h6>Blogs Posted (<%= user.blogCount %>)</h6>
                    <div class="blog-list">
                        <% if (user.blogs.length === 0) { %>
                            <p class="text-muted small">No blogs yet.</p>
                        <% } else { %>
                            <ul class="list-group">
                                <% user.blogs.forEach(blog => { %>
                                    <li class="list-group-item small">
                                        <%= blog.title %>
                                        <span class="text-muted float-end">
                                            <%= new Date(blog.createdAt).toLocaleDateString() %>
                                        </span>
                                    </li>
                                <% }) %>
                            </ul>
                        <% } %>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>

    <script>
        document.querySelectorAll('.delete-btn').forEach(btn => {
            btn.addEventListener('click', async () => {
                if (!confirm('Are you sure you want to delete this user and ALL their blogs?')) return;

                const userId = btn.dataset.id;

                const res = await fetch(`/admin/users/${userId}`, {
                    method: 'DELETE'
                });

                const data = await res.json();

                if (data.success) {
                    alert(data.message);
                    location.reload();
                } else {
                    alert(data.message);
                }
            });
        });
    </script>
</body>
</html>
