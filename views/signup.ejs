<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign Up</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 15px; }
    .signup-card { background: white; border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.2); max-width: 420px; width: 100%; padding: 1.8rem; }
    .otp-section { display: flex; align-items: flex-end; gap: 10px; }
    .otp-container { display: flex; gap: 6px; flex: 1; }
    .otp-box { width: 42px; height: 50px; text-align: center; font-size: 1.3rem; font-weight: bold; border: 2px solid #ddd; border-radius: 8px; outline: none; }
    .otp-box:focus { border-color: #667eea; box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.25); }
    .send-otp-btn { height: 50px; padding: 0 16px; white-space: nowrap; font-weight: 500; flex-shrink: 0; }
    #message { margin-top: 10px; padding: 10px; border-radius: 8px; text-align: center; font-weight: 500; }
  </style>
</head>
<body>
  <div class="signup-card">
    <h2 class="text-center mb-4">Create Account</h2>
    <div id="message" style="display: none;"></div>

    <form id="signupForm">
      <div class="mb-3">
        <label class="form-label">Full Name</label>
        <input type="text" class="form-control" id= "fullName" name="fullName" placeholder="John Doe" required>
      </div>

      <div class="mb-3">
        <label class="form-label">Email Address</label>
        <input type="email" class="form-control" id="email" name="email" placeholder="you@example.com" required>
      </div>

      <div class="mb-3">
        <label class="form-label">Password</label>
        <input type="password" class="form-control" name="password" placeholder="••••••••" required>
      </div>

      <div class="mb-4">
        <label class="form-label">Verification Code</label>
        <div class="otp-section">
          <div class="otp-container" id="otpContainer">
            <input type="text" class="otp-box" maxlength="1" data-index="0" oninput="moveToNext(this)" onkeypress="return event.charCode >= 48 && event.charCode <= 57">
            <input type="text" class="otp-box" maxlength="1" data-index="1" oninput="moveToNext(this)" onkeypress="return event.charCode >= 48 && event.charCode <= 57">
            <input type="text" class="otp-box" maxlength="1" data-index="2" oninput="moveToNext(this)" onkeypress="return event.charCode >= 48 && event.charCode <= 57">
            <input type="text" class="otp-box" maxlength="1" data-index="3" oninput="moveToNext(this)" onkeypress="return event.charCode >= 48 && event.charCode <= 57">
            <input type="text" class="otp-box" maxlength="1" data-index="4" oninput="moveToNext(this)" onkeypress="return event.charCode >= 48 && event.charCode <= 57">
            <input type="text" class="otp-box" maxlength="1" data-index="5" oninput="moveToNext(this)" onkeypress="return event.charCode >= 48 && event.charCode <= 57">
          </div>
          <button type="button" class="btn btn-primary send-otp-btn" id="sendOtpBtn">Send OTP</button>
        </div>
        <input type="hidden" name="otp" id="hiddenOtp">
      </div>

      <button type="submit" class="btn btn-success w-100 py-3 fw-bold fs-5" id="submitBtn">Create Account</button>
    </form>

    <p class="text-center mt-3 mb-0">
      Already have an account? <a href="/user/signin">Login</a>
    </p>
  </div>

  <script>
    function moveToNext(current) {
      const index = parseInt(current.dataset.index);
      const boxes = document.querySelectorAll('.otp-box');
      let otpValue = '';
      boxes.forEach(box => otpValue += box.value);
      document.getElementById('hiddenOtp').value = otpValue;
      if (current.value.length === 1 && index < 5) boxes[index + 1].focus();
    }

    function showMessage(text, type = 'danger') {
      const msg = document.getElementById('message');
      msg.textContent = text;
      msg.style.display = 'block';
      msg.className = `alert alert-${type}`;
    }

    // Send OTP
    document.getElementById('sendOtpBtn').addEventListener('click', async function() {
      const email = document.getElementById('email').value.trim();
      if (!email) return showMessage("Please enter email first!", "warning");

      this.disabled = true;
      this.textContent = "Sending...";

      try {
        const res = await fetch('/user/send-otp', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email })
        });

        const data = await res.json();

        if (data.success) {
          showMessage(`✅ OTP sent to ${email}`, "success");
          this.textContent = "Resend OTP";
          setTimeout(() => this.disabled = false, 30000);
        } else {
          showMessage(data.message, "danger");
          this.disabled = false;
          this.textContent = "Send OTP";
        }
      } catch (err) {
        showMessage("Failed to send OTP. Check console.", "danger");
        this.disabled = false;
        this.textContent = "Send OTP";
      }
    });

    // Signup
    document.getElementById('signupForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      const submitBtn = document.getElementById('submitBtn');
      submitBtn.disabled = true;
      submitBtn.textContent = "Creating...";

      const formData = new FormData(this);
      const data = Object.fromEntries(formData.entries());

      try {
        const res = await fetch('/user/signup', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        const result = await res.json();

        if (result.success) {
          showMessage("🎉 Account created! Redirecting...", "success");
          setTimeout(() => window.location.href = "/", 1500);
        } else {
          showMessage(result.message, "danger");
          submitBtn.disabled = false;
          submitBtn.textContent = "Create Account";
        }
      } catch (err) {
        showMessage("Something went wrong.", "danger");
        submitBtn.disabled = false;
        submitBtn.textContent = "Create Account";
      }
    });
  </script>
</body>
</html>
