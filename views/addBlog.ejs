<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title>Write New Blog | Blogify</title>
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
</head>
<body>
    <%- include("./partials/nave") %>

    <div class="container mt-5 mb-5" style="max-width: 900px;">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h2 class="fw-bold"><i class="fas fa-pen-fancy"></i> Write New Blog</h2>
            <a href="/user/profile" class="btn btn-outline-primary">
                <i class="fas fa-arrow-left"></i> My Blogs
            </a>
        </div>

        <% if (locals.error) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle"></i> <%= locals.error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <form action="/blogs/add-new" method="POST" enctype="multipart/form-data" id="blogForm">
            <div class="card shadow-sm mb-4">
                <div class="card-body p-4">
                    <div class="mb-4">
                        <label class="form-label">Blog Title *</label>
                        <input type="text" name="title" class="form-control form-control-lg" 
                               placeholder="Enter an engaging title" maxlength="200" required>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Blog Excerpt</label>
                        <textarea name="excerpt" class="form-control" rows="2" maxlength="300"></textarea>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Cover Image</label>
                        <div class="input-group">
                            <input type="file" name="coverImage" class="form-control" accept="image/*" id="coverImageInput">
                        </div>
                        <div id="imagePreview" class="mt-2"></div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Tags</label>
                        <input type="text" name="tags" class="form-control" placeholder="tag1, tag2, tag3" id="tagsInput">
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Blog Content *</h5>
                </div>
                <div class="card-body p-0">
                    <div id="editor" style="height: 450px;"></div>
                </div>
            </div>
            <input type="hidden" name="body" id="blogContent">

            <div class="d-flex gap-2 justify-content-end">
                <a href="/" class="btn btn-outline-secondary btn-lg">Cancel</a>
                <button type="submit" class="btn btn-primary btn-lg">Publish Blog</button>
            </div>
        </form>
    </div>

    <%- include("./partials/scripts") %>

    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
    <script>
        const quill = new Quill('#editor', {
            theme: 'snow',
            modules: {
                toolbar: [
                    [{ 'header': [1, 2, 3, false] }],
                    ['bold', 'italic', 'underline', 'strike'],
                    ['blockquote', 'code-block'],
                    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                    [{ 'color': [] }, { 'background': [] }],
                    ['link', 'image'],
                    ['clean']
                ]
            },
            placeholder: 'Write your content here...'
        });

        document.getElementById('blogForm').addEventListener('submit', (e) => {
            e.preventDefault();
            document.getElementById('blogContent').value = quill.root.innerHTML;
            e.target.submit();
        });
    </script>
</body>
</html>
