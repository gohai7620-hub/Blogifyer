<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title>Write New Blog | Blogify</title>
    <!-- Rich Text Editor (Quill) -->
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
</head>
<body>
    <%- include("./partials/nave") %>

    <div class="container mt-5 mb-5" style="max-width: 900px;">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h2 class="fw-bold"><i class="fas fa-pen-fancy"></i> Write New Blog</h2>
            <a href="/user/profile" class="btn btn-outline-primary">
                <i class="fas fa-arrow-left"></i> My Blogs
            </a>
        </div>

        <% if (locals.error) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle"></i> <%= locals.error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <form action="/blogs/add-new" method="POST" enctype="multipart/form-data" id="blogForm">
            <div class="card shadow-sm mb-4">
                <div class="card-body p-4">
                    <!-- Title -->
                    <div class="mb-4">
                        <label class="form-label">Blog Title *</label>
                        <input type="text" name="title" class="form-control form-control-lg" 
                               placeholder="Enter an engaging title for your blog"
                               maxlength="200" required>
                        <small class="text-muted">Max 200 characters</small>
                    </div>

                    <!-- Excerpt -->
                    <div class="mb-4">
                        <label class="form-label">Blog Excerpt (Summary)</label>
                        <textarea name="excerpt" class="form-control" rows="2"
                                  placeholder="A brief summary of your blog (optional)"
                                  maxlength="300"></textarea>
                        <small class="text-muted">Max 300 characters - will show on blog cards</small>
                    </div>

                    <!-- Meta Description -->
                    <div class="mb-4">
                        <label class="form-label">Meta Description (SEO)</label>
                        <input type="text" name="metaDescription" class="form-control"
                               placeholder="Description for search engines"
                               maxlength="160">
                        <small class="text-muted">Max 160 characters for SEO</small>
                    </div>

                    <!-- Cover Image -->
                    <div class="mb-4">
                        <label class="form-label">Cover Image</label>
                        <div class="input-group">
                            <input type="file" name="coverImage" class="form-control" 
                                   accept="image/*" id="coverImageInput">
                            <label class="input-group-text" for="coverImageInput">
                                <i class="fas fa-upload"></i>
                            </label>
                        </div>
                        <small class="text-muted">Recommended size: 1200x600px, Max 5MB</small>
                        <div id="imagePreview" class="mt-2"></div>
                    </div>

                    <!-- Tags -->
                    <div class="mb-4">
                        <label class="form-label">Tags (Optional)</label>
                        <input type="text" name="tags" class="form-control" 
                               placeholder="Add tags separated by comma (e.g., javascript, web-development, nodejs)"
                               id="tagsInput">
                        <div id="tagsList" class="mt-2"></div>
                        <small class="text-muted">Max 10 tags, separated by commas</small>
                    </div>

                    <!-- Category -->
                    <div class="mb-4">
                        <label class="form-label">Category</label>
                        <select name="category" class="form-select">
                            <option value="General">General</option>
                            <option value="Technology">Technology</option>
                            <option value="Business">Business</option>
                            <option value="Lifestyle">Lifestyle</option>
                            <option value="Travel">Travel</option>
                            <option value="Health">Health</option>
                            <option value="Education">Education</option>
                            <option value="Entertainment">Entertainment</option>
                        </select>
                    </div>

                    <!-- Status -->
                    <div class="mb-4">
                        <label class="form-label">Status</label>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="status" 
                                   id="statusPublished" value="published" checked>
                            <label class="form-check-label" for="statusPublished">
                                <i class="fas fa-globe"></i> Publish Now
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="status" 
                                   id="statusDraft" value="draft">
                            <label class="form-check-label" for="statusDraft">
                                <i class="fas fa-file"></i> Save as Draft
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Rich Text Editor -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Blog Content *</h5>
                </div>
                <div class="card-body p-0">
                    <div id="editor" class="form-control" style="height: 400px; border: none; border-radius: 0;"></div>
                </div>
            </div>
            <input type="hidden" name="body" id="blogContent">

            <!-- Preview Section -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Preview</h5>
                    <button type="button" class="btn btn-sm btn-outline-primary" id="previewBtn">
                        <i class="fas fa-eye"></i> Show Preview
                    </button>
                </div>
                <div class="card-body" id="previewContent" style="display: none;">
                    <img id="previewImage" src="" alt="Preview" class="img-fluid mb-3 rounded" style="display: none;">
                    <h3 id="previewTitle">Blog Title</h3>
                    <p id="previewExcerpt" class="text-muted">Blog excerpt will appear here...</p>
                </div>
            </div>

            <!-- Submit Buttons -->
            <div class="d-flex gap-2 justify-content-end">
                <a href="/" class="btn btn-outline-secondary btn-lg">
                    <i class="fas fa-times"></i> Cancel
                </a>
                <button type="submit" class="btn btn-primary btn-lg" id="submitBtn">
                    <i class="fas fa-save"></i> <span id="submitText">Publish Blog</span>
                </button>
            </div>
        </form>
    </div>

    <%- include("./partials/scripts") %>

    <!-- Quill Editor -->
    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>

    <script>
        // Initialize Quill Editor
        const quill = new Quill('#editor', {
            theme: 'snow',
            modules: {
                toolbar: [
                    [{ 'header': [1, 2, 3, 4, 5, 6, false] }],
                    ['bold', 'italic', 'underline', 'strike'],
                    ['blockquote', 'code-block'],
                    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                    [{ 'color': [] }, { 'background': [] }],
                    ['link', 'video'],
                    ['clean']
                ]
            },
            placeholder: 'Write your blog content here...'
        });

        // Image Preview
        document.getElementById('coverImageInput').addEventListener('change', (e) => {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = (event) => {
                    const preview = document.getElementById('imagePreview');
                    preview.innerHTML = `
                        <img src="${event.target.result}" 
                             class="img-thumbnail" 
                             style="max-width: 200px; max-height: 150px; object-fit: cover;">
                    `;
                    document.getElementById('previewImage').src = event.target.result;
                    document.getElementById('previewImage').style.display = 'block';
                };
                reader.readAsDataURL(file);
            }
        });

        // Tags Handler
        const tagsInput = document.getElementById('tagsInput');
        tagsInput.addEventListener('change', () => {
            const tags = tagsInput.value.split(',').map(t => t.trim()).filter(t => t);
            const tagsList = document.getElementById('tagsList');
            tagsList.innerHTML = tags.slice(0, 10).map(tag => `
                <span class="badge bg-primary me-2 mb-2">
                    ${tag}
                    <i class="fas fa-times ms-1" style="cursor: pointer;"></i>
                </span>
            `).join('');
        });

        // Preview Toggle
        document.getElementById('previewBtn').addEventListener('click', () => {
            const previewContent = document.getElementById('previewContent');
            previewContent.style.display = previewContent.style.display === 'none' ? 'block' : 'none';
            
            // Update preview
            document.getElementById('previewTitle').textContent = 
                document.querySelector('input[name="title"]').value || 'Blog Title';
            document.getElementById('previewExcerpt').textContent = 
                document.querySelector('textarea[name="excerpt"]').value || 'Blog excerpt...';
        });

        // Update submit button text based on status
        document.querySelectorAll('input[name="status"]').forEach(radio => {
            radio.addEventListener('change', (e) => {
                const submitText = document.getElementById('submitText');
                submitText.textContent = e.target.value === 'draft' ? 'Save as Draft' : 'Publish Blog';
            });
        });

        // Form Submit
        document.getElementById('blogForm').addEventListener('submit', (e) => {
            e.preventDefault();
            
            // Get editor content
            const editorContent = quill.root.innerHTML;
            if (editorContent.trim() === '<p><br></p>' || editorContent.trim() === '') {
                notify.error('Please write some content for your blog');
                return;
            }

            document.getElementById('blogContent').value = editorContent;

            // Validate
            const title = document.querySelector('input[name="title"]').value.trim();
            if (!title) {
                notify.error('Please enter a blog title');
                return;
            }

            if (title.length > 200) {
                notify.error('Title cannot exceed 200 characters');
                return;
            }

            // Submit form
            const submitBtn = document.getElementById('submitBtn');
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Saving...';

            // Actually submit the form via default action
            setTimeout(() => {
                document.getElementById('blogForm').submit();
            }, 500);
        });

        // Auto-save to localStorage
        const autoSaveKey = 'blogify_draft_' + Date.now();
        setInterval(() => {
            const blogData = {
                title: document.querySelector('input[name="title"]').value,
                excerpt: document.querySelector('textarea[name="excerpt"]').value,
                tags: document.querySelector('input[name="tags"]').value,
                category: document.querySelector('select[name="category"]').value,
                content: quill.root.innerHTML
            };
            localStorage.setItem(autoSaveKey, JSON.stringify(blogData));
        }, 30000); // Auto-save every 30 seconds
    </script>
</body>
</html>
